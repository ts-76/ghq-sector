{
  "name": "ghq-sector",
  "version": "0.1.4",
  "description": "Node.js CLI for AI-assisted and human-curated ghq workspaces with categorized symlinks, portable config paths, and a local config editor.",
  "license": "MIT",
  "author": "ts-76",
  "private": false,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ts-76/ghq-sector.git"
  },
  "homepage": "https://npmx.dev/package/ghq-sector",
  "bugs": {
    "url": "https://github.com/ts-76/ghq-sector/issues"
  },
  "bin": {
    "gsec": "./dist/cli/main.mjs",
    "ghq-sector": "./dist/cli/main.mjs"
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "cli": "tsx src/cli/main.ts",
    "lint": "bunx @biomejs/biome ci .",
    "test": "vitest run --maxWorkers 1",
    "typecheck": "tsc --noEmit",
    "build-ui": "bun install --cwd ui && bun run --cwd ui build",
    "sync-ui-dist": "mkdir -p dist/ui-dist && rm -rf dist/ui-dist/assets && cp -R ui/dist/* dist/ui-dist/",
    "build-bin": "tsdown --entry src/cli/main.ts --format esm --out-dir dist/cli --target node20",
    "build": "bun run build-ui && bun run sync-ui-dist && bun run build-bin",
    "audit": "bun audit --audit-level=moderate",
    "release": "semantic-release"
  },
  "keywords": [
    "ghq",
    "workspace",
    "cli",
    "developer-tools",
    "ai",
    "ai-agent",
    "ai-agents",
    "coding-assistant",
    "codex",
    "claude-code",
    "copilot",
    "repo-management",
    "vscode",
    "visual-json"
  ],
  "dependencies": {
    "cac": "^7.0.0",
    "valibot": "^1.3.1",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@socketsecurity/bun-security-scanner": "^1.1.2",
    "@types/node": "^24.12.2",
    "semantic-release": "^25.0.3",
    "tsdown": "^0.21.10",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
